generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Role {
  CREATOR
  DIRECTOR
  ADMIN
}

enum VideoStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  REVISION_REQUESTED
  REVISED
  APPROVED
  FINAL_REVIEW
  COMPLETED

  @@map("video_status")
}

enum VideoType {
  ORIGINAL
  REMAKE
  OTHER

  @@map("video_type")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED

  @@map("project_status")
}

enum CompensationType {
  PER_VIDEO
  CUSTOM

  @@map("compensation_type")
}

enum EntityType {
  INDIVIDUAL
  CORPORATION

  @@map("entity_type")
}

enum InvoiceVerificationStatus {
  PENDING
  MATCHED
  MISMATCHED
  APPROVED

  @@map("invoice_verification_status")
}

enum InvoiceActionType {
  UPLOAD
  GENERATE
  APPROVE

  @@map("invoice_action_type")
}

// ============================================================
// LM動画納品システム Enums
// ============================================================

enum DeliveryScheduleStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  FAILED

  @@map("delivery_schedule_status")
}

enum DeliveryChangeAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  SEND

  @@map("delivery_change_action")
}

// ============================================================
// Models
// ============================================================

model User {
  id           String   @id @default(cuid())
  loginId      String   @unique @map("login_id")
  passwordHash String   @map("password_hash")
  name         String
  email        String?
  role         Role     @default(CREATOR)
  chatworkId           String?  @map("chatwork_id")
  chatworkRoomId       String?  @map("chatwork_room_id")
  googleDriveFolderId  String?  @map("google_drive_folder_id")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  createdProjects   Project[]          @relation("ProjectCreatedBy")
  directorProjects  ProjectDirector[]
  createdVideos     Video[]            @relation("VideoCreator")
  directedVideos    Video[]            @relation("VideoDirector")
  versions          Version[]
  feedbacks         Feedback[]
  triggeredNotifications Notification[] @relation("NotificationTriggeredBy")
  targetNotifications    Notification[] @relation("NotificationTarget")
  compensation      CreatorCompensation?
  profile            CreatorProfile?
  paymentNotifications    PaymentNotification[]  @relation("PaymentNotificationCreator")
  generatedNotifications  PaymentNotification[]  @relation("PaymentNotificationGenerator")
  uploadedInvoices   CreatorInvoice[] @relation("InvoiceUploader")
  approvedInvoices   CreatorInvoice[] @relation("InvoiceApprover")
  invoiceHistoryActions InvoiceHistory[] @relation("InvoiceHistoryActor")

  // LM動画納品システム Relations
  deliveryApprovals  DeliveryApproval[]
  deliveryChangeLogs DeliveryChangeLog[]

  @@map("users")
}

model Project {
  id                  String        @id @default(cuid())
  projectCode         String        @unique @map("project_code")
  name                String
  description         String?
  googleDriveFolderId String?       @map("google_drive_folder_id")
  deadline            DateTime?
  status              ProjectStatus @default(ACTIVE)
  createdBy           String        @map("created_by")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  creator    User              @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  directors  ProjectDirector[]
  videos     Video[]

  @@index([status])
  @@index([createdBy])
  @@map("projects")
}

model ProjectDirector {
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_directors")
}

model Video {
  id                  String      @id @default(cuid())
  videoCode           String      @unique @map("video_code")
  projectId           String      @map("project_id")
  title               String
  creatorId           String      @map("creator_id")
  directorId          String?     @map("director_id")
  status              VideoStatus @default(DRAFT)
  videoType           VideoType?  @map("video_type")
  videoTypeOther      String?     @map("video_type_other")
  googleDriveFolderId String?     @map("google_drive_folder_id")
  deadline            DateTime?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator       User           @relation("VideoCreator", fields: [creatorId], references: [id])
  director      User?          @relation("VideoDirector", fields: [directorId], references: [id])
  referenceUrls ReferenceUrl[]
  versions      Version[]
  feedbacks     Feedback[]
  notifications Notification[]

  @@index([status])
  @@index([creatorId])
  @@index([directorId])
  @@index([projectId])
  @@index([creatorId, status])
  @@index([projectId, status])
  @@map("videos")
}

model ReferenceUrl {
  id        String   @id @default(cuid())
  videoId   String   @map("video_id")
  url       String
  platform  String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@map("reference_urls")
}

model Version {
  id               String   @id @default(cuid())
  videoId          String   @map("video_id")
  versionNumber    Int      @map("version_number")
  fileName         String   @map("file_name")
  fileSize         BigInt   @map("file_size")
  mimeType         String?  @map("mime_type")
  googleDriveFileId String? @map("google_drive_file_id")
  googleDriveUrl   String?  @map("google_drive_url")
  blobUrl          String?  @map("blob_url") @db.Text
  uploadedBy       String   @map("uploaded_by")
  createdAt        DateTime @default(now()) @map("created_at")

  // テロップ書き起こし
  telopText        String?   @map("telop_text") @db.Text
  telopExtractedAt DateTime? @map("telop_extracted_at")

  // 音声書き起こし
  audioText        String?   @map("audio_text") @db.Text
  audioExtractedAt DateTime? @map("audio_extracted_at")

  // Relations
  video     Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  uploader  User       @relation(fields: [uploadedBy], references: [id])
  feedbacks Feedback[]

  @@unique([videoId, versionNumber])
  @@index([videoId])
  @@map("versions")
}

model Feedback {
  id             String   @id @default(cuid())
  versionId      String   @map("version_id")
  videoId        String   @map("video_id")
  userId         String   @map("user_id")
  comment        String
  videoTimestamp  Float?   @map("video_timestamp")
  actionType     String?  @map("action_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  version Version @relation(fields: [versionId], references: [id], onDelete: Cascade)
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([versionId])
  @@index([videoId])
  @@index([userId])
  @@map("feedbacks")
}

model GoogleDriveSetting {
  id                String   @id @default(cuid())
  name              String
  driveId           String?  @map("drive_id")
  rootFolderId      String?  @map("root_folder_id")
  serviceAccountKey String?  @map("service_account_key") @db.Text
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("google_drive_settings")
}

model Notification {
  id           String   @id @default(cuid())
  type         String
  videoId      String?  @map("video_id")
  triggeredBy  String   @map("triggered_by")
  targetUserId String   @map("target_user_id")
  message      String
  chatworkSent Boolean  @default(false) @map("chatwork_sent")
  isRead       Boolean  @default(false) @map("is_read")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  video      Video? @relation(fields: [videoId], references: [id], onDelete: SetNull)
  triggerer  User   @relation("NotificationTriggeredBy", fields: [triggeredBy], references: [id])
  targetUser User   @relation("NotificationTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId, isRead])
  @@index([videoId])
  @@map("notifications")
}

model CreatorCompensation {
  id             String           @id @default(cuid())
  userId         String           @unique @map("user_id")
  type           CompensationType @default(PER_VIDEO)
  perVideoRate   Int?             @map("per_video_rate")
  customAmount   Int?             @map("custom_amount")
  customNote     String?          @map("custom_note")
  isFixedMonthly Boolean          @default(false) @map("is_fixed_monthly")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_compensations")
}

model CreatorProfile {
  id                String     @id @default(cuid())
  userId            String     @unique @map("user_id")
  entityType        EntityType @default(INDIVIDUAL) @map("entity_type")
  businessName      String?    @map("business_name")
  postalCode        String?    @map("postal_code")
  address           String?
  invoiceNumber     String?    @map("invoice_number")
  bankName          String?    @map("bank_name")
  bankBranch        String?    @map("bank_branch")
  bankAccountType   String?    @map("bank_account_type")
  bankAccountNumber String?    @map("bank_account_number")
  bankAccountHolder String?    @map("bank_account_holder")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_profiles")
}

model PaymentNotification {
  id              String   @id @default(cuid())
  creatorId       String   @map("creator_id")
  year            Int
  month           Int
  subtotal        Int
  consumptionTax  Int      @default(0) @map("consumption_tax")
  withholdingTax  Int      @map("withholding_tax")
  netAmount       Int      @map("net_amount")
  lineItemsJson   Json     @map("line_items_json")
  generatedBy     String   @map("generated_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  creator   User @relation("PaymentNotificationCreator", fields: [creatorId], references: [id])
  generator User @relation("PaymentNotificationGenerator", fields: [generatedBy], references: [id])
  invoice   CreatorInvoice?
  history   InvoiceHistory[]

  @@unique([creatorId, year, month])
  @@map("payment_notifications")
}

model CompanySettings {
  id            String   @id @default(cuid())
  companyName   String   @map("company_name")
  postalCode    String?  @map("postal_code")
  address       String?
  tel           String?
  email         String?
  invoiceNumber String?  @map("invoice_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

model NotificationTemplate {
  id              String   @id @default(cuid())
  type            String   @unique
  title           String
  messageTemplate String   @map("message_template") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model CreatorInvoice {
  id                     String                    @id @default(cuid())
  paymentNotificationId  String                    @unique @map("payment_notification_id")
  uploadedBy             String                    @map("uploaded_by")
  filePath               String                    @map("file_path")
  fileName               String                    @map("file_name")
  fileSize               Int                       @map("file_size")
  extractedSubtotal      Int?                      @map("extracted_subtotal")
  extractedWithholding   Int?                      @map("extracted_withholding")
  extractedNetAmount     Int?                      @map("extracted_net_amount")
  verificationStatus     InvoiceVerificationStatus @default(PENDING)
  verifiedAt             DateTime?                 @map("verified_at")
  approvedBy             String?                   @map("approved_by")
  approvedAt             DateTime?                 @map("approved_at")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")

  paymentNotification PaymentNotification @relation(fields: [paymentNotificationId], references: [id], onDelete: Cascade)
  uploader            User                @relation("InvoiceUploader", fields: [uploadedBy], references: [id])
  approver            User?               @relation("InvoiceApprover", fields: [approvedBy], references: [id])

  @@map("creator_invoices")
}

model InvoiceHistory {
  id                    String                     @id @default(cuid())
  paymentNotificationId String                     @map("payment_notification_id")
  actionType            InvoiceActionType          @map("action_type")
  actorId               String                     @map("actor_id")
  filePath              String?                    @map("file_path")
  fileName              String?                    @map("file_name")
  fileSize              Int?                       @map("file_size")
  extractedSubtotal     Int?                       @map("extracted_subtotal")
  extractedWithholding  Int?                       @map("extracted_withholding")
  extractedNetAmount    Int?                       @map("extracted_net_amount")
  verificationStatus    InvoiceVerificationStatus? @map("verification_status")
  createdAt             DateTime                   @default(now()) @map("created_at")

  paymentNotification PaymentNotification @relation(fields: [paymentNotificationId], references: [id], onDelete: Cascade)
  actor               User                @relation("InvoiceHistoryActor", fields: [actorId], references: [id])

  @@index([paymentNotificationId, createdAt])
  @@map("invoice_history")
}

// ============================================================
// LM動画納品システム Models
// ============================================================

model DeliveryClient {
  id              String   @id @default(cuid())
  name            String
  lineGroupId     String?  @map("line_group_id")
  googleDriveFolderId String? @map("google_drive_folder_id")
  contactName     String?  @map("contact_name")
  contactEmail    String?  @map("contact_email")
  note            String?  @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  videoStocks       VideoStock[]
  deliverySchedules DeliverySchedule[]

  @@map("delivery_clients")
}

model VideoStock {
  id                String    @id @default(cuid())
  title             String
  fileName          String    @map("file_name")
  googleDriveFileId String?   @map("google_drive_file_id")
  googleDriveUrl    String?   @map("google_drive_url")
  blobUrl           String?   @map("blob_url") @db.Text
  clientId          String?   @map("client_id")
  isUsed            Boolean   @default(false) @map("is_used")
  usedAt            DateTime? @map("used_at")
  note              String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  client            DeliveryClient?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deliverySchedules DeliverySchedule[]

  @@index([clientId])
  @@index([isUsed])
  @@map("video_stocks")
}

model DeliverySchedule {
  id              String                 @id @default(cuid())
  clientId        String                 @map("client_id")
  videoStockId    String                 @unique @map("video_stock_id")
  weekStart       DateTime               @map("week_start")
  scheduledSendAt DateTime?              @map("scheduled_send_at")
  actualSentAt    DateTime?              @map("actual_sent_at")
  status          DeliveryScheduleStatus @default(DRAFT)
  sendError       String?                @map("send_error") @db.Text
  calendarEventId String?                @map("calendar_event_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  // Relations
  client     DeliveryClient     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  videoStock VideoStock          @relation(fields: [videoStockId], references: [id], onDelete: Cascade)
  approvals  DeliveryApproval[]
  changeLogs DeliveryChangeLog[]

  @@index([clientId])
  @@index([weekStart])
  @@index([status])
  @@index([weekStart, status])
  @@map("delivery_schedules")
}

model DeliveryApproval {
  id         String   @id @default(cuid())
  scheduleId String   @map("schedule_id")
  approvedBy String   @map("approved_by")
  approvedAt DateTime @default(now()) @map("approved_at")

  // Relations
  schedule DeliverySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  approver User             @relation(fields: [approvedBy], references: [id])

  @@unique([scheduleId, approvedBy])
  @@index([scheduleId])
  @@map("delivery_approvals")
}

model DeliveryChangeLog {
  id         String               @id @default(cuid())
  scheduleId String?              @map("schedule_id")
  action     DeliveryChangeAction
  actorId    String               @map("actor_id")
  detail     Json?
  createdAt  DateTime             @default(now()) @map("created_at")

  // Relations
  schedule DeliverySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  actor    User              @relation(fields: [actorId], references: [id])

  @@index([scheduleId])
  @@index([actorId])
  @@index([createdAt])
  @@map("delivery_change_logs")
}
